# LLM provider API keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=
# OPENAI_API_VERSION=2025-03-01-preview

# Optional market/data provider credentials
ALPHA_VANTAGE_API_KEY=
COINGECKO_API_KEY=
# COINGECKO_PLAN=demo          # Options: demo, basic (default: demo)
# COINGECKO_RATE_LIMIT_RPM=    # Override per-tier default (demo=30, basic=250)
# COINGECKO_MAX_CONCURRENT=    # Override per-tier default (demo=2, basic=5)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Trading Accounts Dashboard — encryption key for stored API credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ACCOUNTS_ENCRYPTION_KEY=

# TradingAgents defaults and overrides
# TRADINGAGENTS_LLM_PROVIDER=openai
# TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
# TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
# TRADINGAGENTS_BACKEND_URL=
# TRADINGAGENTS_RESULTS_DIR=~/.tradingagents/logs
# TRADINGAGENTS_CACHE_DIR=~/.tradingagents/cache
# TRADINGAGENTS_MEMORY_LOG_PATH=~/.tradingagents/memory/trading_memory.md
# DATABASE_URL=postgresql://postgres:password@localhost:5432/tradingagents
# Note: docker-compose sets DATABASE_URL=postgresql://postgres:postgres@db:5432/tradingagents
# Override in .env only if using an external database

# Web API / browser security
# WEB_CORS_ORIGIN=http://localhost:5177
# WEB_CSP_CONNECT_SRC='self' ws://localhost:5177 ws://localhost:8877 wss://localhost:5177 wss://localhost:8877

# Server bind contract (read by start.sh / start.bat and reported in the MCP console)
# SECURITY: the trading API has NO authentication — the loopback bind IS the security
# boundary. Keep these at loopback unless you front the app with an authenticated proxy.
#   TRADINGAGENTS_BIND_HOST  host uvicorn/vite bind to. Default 127.0.0.1 (loopback).
#                            0.0.0.0 exposes real-money trade placement to the network.
#   TRADINGAGENTS_PORT       backend API port. Default 8877 (vite dev proxy follows it).
# TRADINGAGENTS_BIND_HOST=127.0.0.1
# TRADINGAGENTS_PORT=8877
# Docker only: host interface the published ports bind to (the REAL container boundary;
# the in-container bind is always 0.0.0.0). Default 127.0.0.1 = host-loopback-only.
# TRADINGAGENTS_HOST_BIND=127.0.0.1

# Runtime controls
# LLM_MAX_CONCURRENT=0
# LLM_MIN_SPACING_MS=0
# THREADPOOL_MAX_WORKERS=32
